{
  "name": "titimenu-print-bridge",
  "version": "1.1.5",
  "description": "TitiMenu Print Bridge - Thermal printer integration",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --x64 --arm64",
    "build:win": "electron-builder --win --x64"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "node-thermal-printer": "^4.3.4",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.titimenu.printbridge",
    "productName": "TitiMenu Print Bridge",
    "files": [
      "main.js",
      "preload.js",
      "printer.js",
      "supabase.js",
      "renderer/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns",
      "artifactName": "TitiMenu-Print-Bridge-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "artifactName": "TitiMenu-Print-Bridge-Setup-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "Sandytheking",
      "repo": "titimenu-print",
      "releaseType": "release"
    }
  }
}
